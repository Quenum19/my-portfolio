# ============================================================
# Variables d'environnement — copier ce fichier en .env.local
# (cp .env.example .env.local) puis remplir les valeurs.
# ============================================================

# --- Formulaire de contact (Resend) ---------------------------------
# Clé API Resend : https://resend.com/api-keys
# Si absente, le formulaire fonctionne en "dry-run" (aucun email envoyé).
RESEND_API_KEY=

# Adresse qui reçoit les messages (par défaut : l'email de lib/data.ts)
CONTACT_TO_EMAIL=

# Expéditeur affiché. Doit être un domaine vérifié sur Resend.
# Par défaut : "Portfolio <onboarding@resend.dev>" (domaine de test Resend).
CONTACT_FROM_EMAIL=

# --- Analytics (Plausible, sans cookie — optionnel) -----------------
# Domaine déclaré dans Plausible. Laisser vide pour désactiver l'analytics.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Hôte du script Plausible (auto-hébergé). Défaut : https://plausible.io
NEXT_PUBLIC_PLAUSIBLE_HOST=

# --- Site -----------------------------------------------------------
# URL publique de production (sitemap, OG).
NEXT_PUBLIC_SITE_URL=

# --- Administration (/admin) ----------------------------------------
# Mot de passe d'accès au tableau de bord admin (obligatoire pour se connecter).
ADMIN_PASSWORD=
# Secret de signature des sessions (chaîne aléatoire longue). Générer avec :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# --- Base de données (injecté automatiquement par Vercel Postgres) --
# POSTGRES_URL=...
# (créé via Vercel : Storage > Create Database > Postgres > Connect Project)

# --- Upload d'images (optionnel, Vercel Blob) -----------------------
# Injecté automatiquement si tu crées un store Blob (Storage > Blob).
# Sans lui, l'admin accepte des URL d'images collées.
# BLOB_READ_WRITE_TOKEN=...
