# ============================================================
# Variables d'environnement — copier ce fichier en .env.local
# (cp .env.example .env.local) puis remplir les valeurs.
# ============================================================

# --- Formulaire de contact (Resend) ---------------------------------
# Clé API Resend : https://resend.com/api-keys
# Si absente, le formulaire fonctionne en "dry-run" (aucun email envoyé).
RESEND_API_KEY=

# Adresse qui reçoit les messages (par défaut : l'email de lib/data.ts)
CONTACT_TO_EMAIL=

# Expéditeur affiché. Doit être un domaine vérifié sur Resend.
# Par défaut : "Portfolio <onboarding@resend.dev>" (domaine de test Resend).
CONTACT_FROM_EMAIL=

# --- Analytics (Plausible, sans cookie — optionnel) -----------------
# Domaine déclaré dans Plausible. Laisser vide pour désactiver l'analytics.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Hôte du script Plausible (auto-hébergé). Défaut : https://plausible.io
NEXT_PUBLIC_PLAUSIBLE_HOST=

# --- Site -----------------------------------------------------------
# URL publique de production (sitemap, OG). Défaut : valeur de lib/data.ts (SITE.url)
NEXT_PUBLIC_SITE_URL=
